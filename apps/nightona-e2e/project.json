{
  "name": "nightona-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/nightona-e2e",
  "tags": [],
  "implicitDependencies": ["api", "runner", "proxy", "dashboard"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test -tags e2e -timeout 300s -v -count=1 ./..."
      },
      "cache": true,
      "inputs": [
        "default",
        "^goProduction",
        { "dependentTasksOutputFiles": "**/*", "transitive": true },
        { "env": "NIGHTONA_API_URL" },
        { "env": "NIGHTONA_API_KEY" }
      ]
    },
    "e2e:cleanup": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test -tags e2e -run TestCleanupStaleSandboxes -v -timeout 60s ./..."
      }
    }
  }
}
