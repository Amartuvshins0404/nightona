          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.heatmap"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT histogram(nightona.sandbox.cpu.utilization, 10, 10) FROM Metric FACET service.name SINCE 1 hour ago"
              }
            ]
          }
        }
      ]
