{
  "name": "Nightona Sandbox Resource Monitoring - Multi-Service",
  "description": "Comprehensive CPU, Memory, and Disk monitoring for Nightona Sandboxes",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Resource Overview",
      "description": "High-level overview of all Nightona Sandbox",
      "widgets": [
        {
          "title": "Sandbox Count",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 2,
            "height": 2
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT uniqueCount(service.name) as 'Active Sandboxes' FROM Metric WHERE service.name LIKE 'sandbox-%' SINCE 5 minutes ago"
              }
            ]
          }
        },
        {
          "title": "Critical Services",
          "layout": {
            "column": 3,
            "row": 1,
            "width": 2,
            "height": 2
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT uniqueCount(service.name) as 'Over Threshold' FROM Metric WHERE nightona.sandbox.cpu.utilization > 80 OR nightona.sandbox.memory.utilization > 80 OR nightona.sandbox.filesystem.utilization > 80 SINCE 5 minutes ago"
              }
            ],
            "thresholds": [
              {
                "alertSeverity": "WARNING",
                "value": 1
              },
              {
                "alertSeverity": "CRITICAL",
                "value": 3
              }
            ]
          }
        },
        {
          "title": "Services Resource Overview",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 8,
            "height": 4
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(service.name) as 'Service', latest(nightona.sandbox.cpu.utilization) as 'CPU %', latest(nightona.sandbox.cpu.`limit`) as 'CPU Cores', latest(nightona.sandbox.memory.utilization) as 'Memory %', latest(nightona.sandbox.memory.usage) / 1073741824 as 'Memory Used (GB)', latest(nightona.sandbox.memory.`limit`) / 1073741824 as 'Memory Limit (GB)', latest(nightona.sandbox.filesystem.utilization) as 'Disk %', latest(nightona.sandbox.filesystem.usage) / 1073741824 as 'Disk Used (GB)', latest(nightona.sandbox.filesystem.total) / 1073741824 as 'Disk Total (GB)' FROM Metric FACET service.name SINCE 5 minutes ago LIMIT 100"
              }
            ]
          }
        },
        {
          "title": "CPU Utilization by Service",
          "layout": {
            "column": 1,
            "row": 3,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(nightona.sandbox.cpu.utilization) as 'CPU %' FROM Metric FACET service.name TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "max": 100,
              "min": 0
            }
          }
        },
        {
          "title": "Memory Utilization by Service",
          "layout": {
            "column": 1,
            "row": 6,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(nightona.sandbox.memory.utilization) as 'Memory %' FROM Metric FACET service.name TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "max": 100,
              "min": 0
            }
          }
        },
        {
          "title": "Disk Utilization by Service",
          "layout": {
            "column": 1,
            "row": 9,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(nightona.sandbox.filesystem.utilization) as 'Disk %' FROM Metric FACET service.name TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "max": 100,
              "min": 0
            }
          }
        },
        {
          "title": "Top CPU Consumers",
          "layout": {
            "column": 5,
            "row": 5,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(nightona.sandbox.cpu.utilization) as 'Avg CPU %' FROM Metric FACET service.name SINCE 1 hour ago LIMIT 10"
              }
            ]
          }
        },
        {
          "title": "Top Memory Consumers",
          "layout": {
            "column": 9,
            "row": 5,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(nightona.sandbox.memory.utilization) as 'Avg Memory %' FROM Metric FACET service.name SINCE 1 hour ago LIMIT 10"
              }
            ]
          }
        },
        {
          "title": "Top Disk Consumers",
          "layout": {
            "column": 5,
            "row": 8,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(nightona.sandbox.filesystem.utilization) as 'Avg Disk %' FROM Metric FACET service.name SINCE 1 hour ago LIMIT 10"
              }
            ]
          }
        },
        {
          "title": "Services Over Threshold",
          "layout": {
            "column": 9,
            "row": 8,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(service.name) as 'Service', latest(nightona.sandbox.cpu.utilization) as 'CPU %', latest(nightona.sandbox.memory.utilization) as 'Memory %', latest(nightona.sandbox.filesystem.utilization) as 'Disk %' FROM Metric WHERE nightona.sandbox.cpu.utilization > 80 OR nightona.sandbox.memory.utilization > 80 OR nightona.sandbox.filesystem.utilization > 80 FACET service.name SINCE 5 minutes ago"
              }
            ]
          }
        },
        {
          "title": "Resource Pressure Score",
          "layout": {
            "column": 5,
            "row": 11,
            "width": 8,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT (average(nightona.sandbox.cpu.utilization) * 0.33) + (average(nightona.sandbox.memory.utilization) * 0.33) + (average(nightona.sandbox.filesystem.utilization) * 0.34) as 'Resource Pressure Score' FROM Metric FACET service.name TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "max": 100,
              "min": 0
            }
          }
        }
      ]
    },
